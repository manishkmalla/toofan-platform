# ─────────────────────────────────────────────
#  TooFan — Production Environment Variables
#  Copy to .env and fill in all values before deploying
#  NEVER commit .env to git
# ─────────────────────────────────────────────

# ── PostgreSQL (used by docker-compose) ──────
POSTGRES_USER=toofan_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Backend ───────────────────────────────────
NODE_ENV=production
FRONTEND_URL=https://yourdomain.com

# JWT (generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=GENERATE_AND_PASTE_HERE
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=GENERATE_AND_PASTE_HERE_DIFFERENT
JWT_REFRESH_EXPIRES_IN=30d

# Firebase
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR KEY HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# eSewa
ESEWA_MERCHANT_ID=your_esewa_merchant_id
ESEWA_SECRET_KEY=your_esewa_secret_key
ESEWA_SUCCESS_URL=https://yourdomain.com/api/payments/esewa/success
ESEWA_FAILURE_URL=https://yourdomain.com/api/payments/esewa/failure

# Khalti
KHALTI_SECRET_KEY=your_khalti_secret_key
KHALTI_PUBLIC_KEY=your_khalti_public_key

# Stripe
STRIPE_SECRET_KEY=sk_live_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Google Maps
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# AWS S3 (for file uploads — recommended for production)
UPLOAD_DRIVER=s3
AWS_ACCESS_KEY_ID=your_iam_access_key
AWS_SECRET_ACCESS_KEY=your_iam_secret_key
AWS_S3_BUCKET=toofan-uploads
AWS_REGION=ap-south-1

# Email
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=your@mailgun.org
SMTP_PASS=your_smtp_password
EMAIL_FROM="TooFan <noreply@yourdomain.com>"

# Sparrow SMS
SPARROW_SMS_TOKEN=your_sparrow_sms_token
SPARROW_SMS_FROM=TooFan

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Dispatch
DISPATCH_RADIUS_KM=5
DISPATCH_OFFER_TIMEOUT_SEC=30
DISPATCH_MAX_RETRY=3
